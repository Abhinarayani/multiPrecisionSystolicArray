; state.S_RX         ; 0               ; 0               ; 0               ; 0                  ; 0            ; 1          ; 1            ;
; state.S_FEED       ; 0               ; 0               ; 0               ; 0                  ; 1            ; 0          ; 1            ;
; state.S_WAIT_VALID ; 0               ; 0               ; 0               ; 1                  ; 0            ; 0          ; 1            ;
; state.S_TX_LOAD    ; 0               ; 0               ; 1               ; 0                  ; 0            ; 0          ; 1            ;
; state.S_TX_SEND    ; 0               ; 1               ; 0               ; 0                  ; 0            ; 0          ; 1            ;
; state.S_TX_WAIT    ; 1               ; 0               ; 0               ; 0                  ; 0            ; 0          ; 1            ;
